---
import '~/styles/global.css';
import { ClientRouter } from 'astro:transitions';
import AuthHeader from '~/components/AuthHeader.astro';
import { siteName, siteLang, themeColor, siteDescription } from '~/data/config';

// Props
interface Props {
  pageTitle?: string;
  title?: string;
  description?: string;
  metaDescription?: string;
  noindex?: boolean;
  requireAuth?: boolean;
}

const {
  pageTitle,
  title,
  description,
  metaDescription,
  noindex = false,
  requireAuth = true,
} = Astro.props;

const finalDescription = metaDescription || description || siteDescription;
const finalPageTitle = pageTitle || title;
const fullTitle = finalPageTitle ? `${finalPageTitle} | ${siteName}` : siteName;
const baseUrl = `${Astro.url.protocol}//${Astro.url.host}`;
const canonicalURL = new URL(Astro.url.pathname, baseUrl).href;
---

<!doctype html>
<html lang={siteLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content={themeColor} />
    <meta name="description" content={finalDescription} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="author" href="humans.txt" />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content={siteName} />

    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:image" content={`${baseUrl}/images/og-image.jpg`} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={siteLang} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={`${baseUrl}/images/og-image.jpg`} />

    <title>{fullTitle}</title>
    <ClientRouter />
  </head>
  <body data-require-auth={requireAuth ? 'true' : 'false'}>
    <AuthHeader />
    <main>
      <slot />
    </main>
  </body>
</html>

<script>
  import { isAuthenticated } from '~/services/auth';

  function checkAuth() {
    const requireAuth = document.body.dataset.requireAuth === 'true';
    if (requireAuth && !isAuthenticated()) {
      window.location.href = '/auth/login';
    }
  }

  // Check on first load
  checkAuth();

  // Re-check on every client-side navigation
  document.addEventListener('astro:after-swap', () => {
    checkAuth();
    scrollTo({ top: history.state.scrollY, behavior: 'instant' });
  });
</script>
