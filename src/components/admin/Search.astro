---
interface Props {
  placeholder?: string;
  id?: string;
}

const { placeholder = 'Search...', id = 'admin-search' } = Astro.props;
---

<div class="relative w-full max-w-sm">
  <div
    class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="size-4 text-gray-400"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"
      ></path>
    </svg>
  </div>
  <input
    type="search"
    id={id}
    placeholder={placeholder}
    autocomplete="off"
    class="w-full rounded border border-gray-200 bg-gray-50 py-2 pl-9 pr-4 text-sm text-gray-800 outline-none transition placeholder:text-gray-400 focus:border-gray-400 focus:bg-white focus:ring-0"
  />
</div>

<script>
  function initSearch() {
    const input = document.querySelector<HTMLInputElement>(
      '[id$="admin-search"], input[type="search"]',
    );
    if (!input) return;

    let debounceTimer: ReturnType<typeof setTimeout>;

    input.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        const query = input.value.trim().toLowerCase();
        // Dispatch a custom event so the parent page can react
        input.dispatchEvent(
          new CustomEvent('admin:search', {
            detail: { query },
            bubbles: true,
          }),
        );
      }, 300);
    });
  }

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>
