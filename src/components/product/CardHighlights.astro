---
const { product } = Astro.props;
const powerMatch = product.description.match(/(\d+(?:\.\d+)?)\s*(?:W|kW)/i);
const power = powerMatch ? powerMatch[0] : null;
const interfaceMatch = product.description.match(
  /\b(CANopen|EtherCAT|Modbus|Pulse)\b/i,
);
const interfaceType = interfaceMatch ? interfaceMatch[0] : null;
---

<ul class="flex flex-wrap gap-2 text-xs text-gray-600 mt-2">
  {
    product.brand?.name && (
      <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
          />
        </svg>
        {product.brand.name}
      </li>
    )
  }
  {
    product.category?.name && (
      <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
          />
        </svg>
        {product.category.name}
      </li>
    )
  }
  {
    product.series?.name && (
      <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
          />
        </svg>
        {product.series.name}
      </li>
    )
  }
  {
    power && (
      <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 10V3L4 14h7v7l9-11h-7z"
          />
        </svg>
        {power}
      </li>
    )
  }
  {
    interfaceType && (
      <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
        <svg
          class="w-3.5 h-3.5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 002-2V6a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
          />
        </svg>
        {interfaceType}
      </li>
    )
  }
  <li class="flex items-center gap-1 bg-gray-100 px-2 py-1 rounded">
    <svg
      class="w-3.5 h-3.5"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"
      ></path>
    </svg>
    Stock: {product.stock}
  </li>
</ul>
