---
import IconLogo from '~/assets/images/icons/logo.svg';

const { product } = Astro.props;
---

<li
  data-product-id={product.id}
  data-product-stock={product.stock}
  class="card-car bg-white shadow overflow-hidden xxl:transition xxl:border-transparent xxl:border-r-4 hover:lg:border-yellow-300"
>
  <a
    href={`/products/${product.id}`}
    class="relative isolate flex flex-col gap-8 xxl:flex-row"
  >
    <div class="relative aspect-[4/3] xxl:w-72 lg:shrink-0 ribbon">
      {
        product.image_url ? (
          <img
            src={product.image_url}
            alt={product.model}
            class="absolute inset-0 size-full bg-gray-50 object-contain"
          />
        ) : (
          <div class="absolute inset-0 text-gray-400 size-full bg-gray-100 flex flex-col gap-4 items-center justify-center">
            <IconLogo class="h-24" />
            <span class="text-gray-400 font-bold italic">Coming Soon</span>
          </div>
        )
      }
    </div>
    <div
      class="flex flex-col items-start lg:py-4 grow max-xxl:px-4 max-lg:pb-8"
    >
      <div
        class="relative xxl:flex xxl:items-start xxl:gap-4 xxl:justify-between w-full"
      >
        <div class="mb-4 lg:mb-6">
          <h2 class="h5 line-clamp-2">
            {product.model}
            {
              product.series.name && (
                <span class="text-base max-xl:block xl:ml-2 text-gray-800 font-normal align-middle">
                  Series: {product.series.name}
                </span>
              )
            }
          </h2>
          <p class="text-base mt-2 line-clamp-3">{product.description}</p>
        </div>
        <!-- Price (if exists) + stock -->
        <div class="text-right shrink-0">
          {
            product.price ? (
              <p class="text-2xl font-bold text-green-600">
                Rp {product.price.toLocaleString('id-ID')}
              </p>
            ) : (
              <p class="text-sm text-gray-500">Call for price</p>
            )
          }
          <p
            class={`text-sm ${product.stock > 0 ? 'text-green-600' : 'text-red-600'}`}
          >
            Stock: {product.stock > 0 ? product.stock : 'Out of stock'}
          </p>
        </div>
      </div>
      <!-- Highlights – you can replace with product specs if available -->
      <div class="mt-auto lg:mb-4">
        <ul class="flex flex-wrap gap-2 text-xs text-gray-600">
          <li class="bg-gray-100 px-2 py-1 rounded">
            ID: {product.id.slice(0, 8)}
          </li>
          <li class="bg-gray-100 px-2 py-1 rounded">
            Brand: {product.brand.name}
          </li>
          <li class="bg-gray-100 px-2 py-1 rounded">
            Category: {product.category.name}
          </li>
          <li class="bg-gray-100 px-2 py-1 rounded">
            Series: {product.series.name}
          </li>
        </ul>
      </div>
    </div>
  </a>
</li>
