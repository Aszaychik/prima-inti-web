---
import { fetchData } from '~/services/api';
import IconSearch from '~/assets/images/icons/search.svg';
import IconChevronDown from '~/assets/images/icons/chevron-down-select.svg';

const response = await fetchData('products');
const products = response.data || [];

// Extract unique brands (using Map to keep full brand object but unique by name)
const uniqueBrands = [
  ...new Map(products.map((p: any) => [p.brand.name, p.brand])).values(),
];
// Extract unique model strings globally
const uniqueModels = [...new Set(products.map((p: any) => p.model))];
// Extract unique categories
const uniqueCategories = [
  ...new Map(products.map((p: any) => [p.category.name, p.category])).values(),
];
---

<form
  id="form-widget-search"
  action="/products"
  method="get"
  class="grid grid-cols-1 lg:grid-cols-2 gap-4"
  data-product-set={JSON.stringify(products)}
>
  <div>
    <label class="sr-only" for="brand">Brand</label>
    <div class="grid grid-cols-1">
      <select
        name="brand"
        id="brand"
        class="appearance-none col-start-1 row-start-1"
      >
        <option value="all">Choose brand</option>
        {
          uniqueBrands.map((brand: any) => (
            <option value={brand.name}>{brand.name}</option>
          ))
        }
      </select>
      <IconChevronDown class="icon-chevron-down" />
    </div>
  </div>
  <div>
    <label class="sr-only" for="model">Model</label>
    <div class="grid grid-cols-1">
      <select
        name="model"
        id="model"
        class="appearance-none col-start-1 row-start-1"
      >
        <option value="all">Choose model</option>
        {
          uniqueModels.map((model: any) => (
            <option value={model}>{model}</option>
          ))
        }
      </select>
      <IconChevronDown class="icon-chevron-down" />
    </div>
  </div>
  <div>
    <label class="sr-only" for="category">Category</label>
    <div class="grid grid-cols-1">
      <select
        name="category"
        id="category"
        class="appearance-none col-start-1 row-start-1"
      >
        <option value="all">Choose category</option>
        {
          uniqueCategories.map((cat: any) => (
            <option value={cat.name}>{cat.name}</option>
          ))
        }
      </select>
      <IconChevronDown class="icon-chevron-down" />
    </div>
  </div>

  <div>
    <button
      type="submit"
      class="bg-yellow-200 mt-1 rounded-md py-1.5 font-semibold w-full hover:opacity-80 transition"
    >
      <IconSearch class="size-5 -mt-0.5 inline-block" />
      <span>Search</span>
    </button>
  </div>
</form>

<script>
  document.addEventListener('astro:page-load', function () {
    const form = document.getElementById(
      'form-widget-search',
    ) as HTMLFormElement;
    if (form) {
      const allProducts = JSON.parse(
        form.getAttribute('data-product-set') || '[]',
      );
      const brandSelect = document.getElementById('brand') as HTMLSelectElement;
      const modelSelect = document.getElementById('model') as HTMLSelectElement;

      const populateModels = (selectedBrand: string) => {
        const uniqueModels = new Set<string>();
        allProducts.forEach((product: any) => {
          if (product.brand.name === selectedBrand) {
            uniqueModels.add(product.model);
          }
        });
        modelSelect.innerHTML = '<option value="all">Choose model</option>';
        uniqueModels.forEach((model) => {
          const option = document.createElement('option');
          option.value = model;
          option.textContent = model;
          modelSelect.appendChild(option);
        });
      };

      populateModels(brandSelect.value);
      brandSelect.addEventListener('change', () =>
        populateModels(brandSelect.value),
      );
    }
  });
</script>
