---
export const prerender = false;
import { fetchData } from '~/services/api';
import IconReset from '~/assets/images/icons/reset.svg';
import IconChevronDown from '~/assets/images/icons/chevron-down-select.svg';
import IconClose from '~/assets/images/icons/close.svg';

// Fetch all products (with brand, category, series objects)
const response = await fetchData('products');
const products = response.data || [];

// Extract unique brands using id as key
const uniqueBrands = [
  ...new Map(products.map((p) => [p.brand.id, p.brand])).values(),
];
const uniqueCategories = [
  ...new Map(products.map((p) => [p.category.id, p.category])).values(),
];
// Series are unique per brand, but we'll compute dynamically based on selected brand
---

<div
  id="sidebar-filter"
  class="fixed lg:relative max-lg:overflow-y-auto shrink-0 inset-y-0 z-50 lg:flex w-full lg:w-80 lg:flex-col max-lg:bg-white transition duration-300 max-lg:opacity-0 max-lg:pointer-events-none"
>
  <div
    class="flex lg:sticky lg:top-8 flex-col gap-y-5 bg-white lg:shadow-md px-6 py-4 relative"
  >
    <button
      id="button-modal-filter-close"
      class="lg:hidden"
      type="button"
      aria-label="Close filter modal"
    >
      <div class="flex justify-end">
        <IconClose class="size-8 bg-gray-800 rounded-full p-1 text-white" />
      </div>
    </button>

    <form
      id="form-filter"
      method="get"
      class="grid grid-cols-1 gap-y-6"
      data-products={JSON.stringify(products)}
    >
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="brand">Brand</label>
          <button id="clear-input-brand" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="brand"
            id="brand"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              uniqueBrands.map((brand) => (
                <option value={brand.id}>{brand.name}</option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Category -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="category">Category</label>
          <button id="clear-input-category" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="category"
            id="category"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              uniqueCategories.map((cat) => (
                <option value={cat.id}>{cat.name}</option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Series (depends on brand) -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="series">Series</label>
          <button id="clear-input-series" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="series"
            id="series"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Model (depends on series and category) -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="model">Model</label>
          <button id="clear-input-model" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="model"
            id="model"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <div class="sticky bottom-0">
        <button type="submit" class="button button-yellow w-full">
          Search <span id="filter-result-found" class="ml-1">(0)</span>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', function () {
    const form = document.getElementById('form-filter') as HTMLFormElement;
    if (!form) return;

    // Get products from form's data attribute
    const productsData = form.getAttribute('data-products');
    if (!productsData) return;
    const allProducts = JSON.parse(productsData);

    const resultSpan = document.getElementById('filter-result-found')!;
    const brandSelect = document.getElementById('brand') as HTMLSelectElement;
    const categorySelect = document.getElementById(
      'category',
    ) as HTMLSelectElement;
    const seriesSelect = document.getElementById('series') as HTMLSelectElement;
    const modelSelect = document.getElementById('model') as HTMLSelectElement;

    // Helper: Get unique series for a given brand ID
    function getSeriesByBrand(brandId) {
      if (brandId === 'all') {
        // All series (unique by id)
        const seriesMap = new Map();
        allProducts.forEach((p) => {
          if (p.series) seriesMap.set(p.series.id, p.series);
        });
        return Array.from(seriesMap.values());
      } else {
        const brandProducts = allProducts.filter((p) => p.brand.id === brandId);
        const seriesMap = new Map();
        brandProducts.forEach((p) => {
          if (p.series) seriesMap.set(p.series.id, p.series);
        });
        return Array.from(seriesMap.values());
      }
    }

    // Helper: Get unique models based on selected series ID and category ID
    function getModelsBySeriesAndCategory(seriesId, categoryId) {
      let filtered = allProducts;
      if (seriesId && seriesId !== 'all') {
        filtered = filtered.filter((p) => p.series?.id === seriesId);
      }
      if (categoryId && categoryId !== 'all') {
        filtered = filtered.filter((p) => p.category.id === categoryId);
      }
      // Extract unique model strings
      const modelSet = new Set(filtered.map((p) => p.model));
      return Array.from(modelSet);
    }

    // Populate series dropdown based on brand
    function populateSeries(selectedBrandId) {
      seriesSelect.innerHTML = '<option value="all">All</option>';
      const seriesList = getSeriesByBrand(selectedBrandId);
      seriesList.forEach((series) => {
        const option = document.createElement('option');
        option.value = series.id;
        option.textContent = series.name;
        seriesSelect.appendChild(option);
      });
    }

    // Populate model dropdown based on series and category
    function populateModels() {
      const selectedSeries = seriesSelect.value;
      const selectedCategory = categorySelect.value;
      const models = getModelsBySeriesAndCategory(
        selectedSeries,
        selectedCategory,
      );
      modelSelect.innerHTML = '<option value="all">All</option>';
      models.forEach((model) => {
        const option = document.createElement('option');
        option.value = model;
        option.textContent = model;
        modelSelect.appendChild(option);
      });
    }

    // Initial setup from URL params
    const urlParams = new URLSearchParams(window.location.search);
    const initialBrand = urlParams.get('brand') || 'all';
    const initialCategory = urlParams.get('category') || 'all';
    const initialSeries = urlParams.get('series') || 'all';
    const initialModel = urlParams.get('model') || 'all';

    if (initialBrand !== 'all') brandSelect.value = initialBrand;
    if (initialCategory !== 'all') categorySelect.value = initialCategory;

    populateSeries(initialBrand);
    // Wait for series to be populated then set value and populate models
    if (initialSeries !== 'all') seriesSelect.value = initialSeries;
    populateModels();
    if (initialModel !== 'all') modelSelect.value = initialModel;

    // Event listeners
    brandSelect.addEventListener('change', () => {
      populateSeries(brandSelect.value);
      // Reset series and model when brand changes
      seriesSelect.value = 'all';
      populateModels();
      modelSelect.value = 'all';
      updateCount();
    });

    categorySelect.addEventListener('change', () => {
      populateModels();
      modelSelect.value = 'all';
      updateCount();
    });

    seriesSelect.addEventListener('change', () => {
      populateModels();
      modelSelect.value = 'all';
      updateCount();
    });

    // Function to count matching products
    function updateCount() {
      const brandId = brandSelect.value;
      const categoryId = categorySelect.value;
      const seriesId = seriesSelect.value;
      const modelValue = modelSelect.value;

      let filtered = allProducts;
      if (brandId !== 'all')
        filtered = filtered.filter((p) => p.brand.id === brandId);
      if (categoryId !== 'all')
        filtered = filtered.filter((p) => p.category.id === categoryId);
      if (seriesId !== 'all')
        filtered = filtered.filter((p) => p.series?.id === seriesId);
      if (modelValue !== 'all')
        filtered = filtered.filter((p) => p.model === modelValue);
      resultSpan.textContent = `(${filtered.length})`;
    }

    form.addEventListener('change', updateCount);
    updateCount();

    // Clear buttons
    const clearButtons = form.querySelectorAll("button[id^='clear-input-']");
    clearButtons.forEach((button) => {
      button.addEventListener('click', (e) => {
        const inputId = button.id.replace('clear-input-', '');
        const input = form.elements.namedItem(inputId) as HTMLSelectElement;
        if (input) {
          input.value = 'all';
          input.dispatchEvent(new Event('change'));
          if (inputId === 'brand') {
            populateSeries('all');
            seriesSelect.value = 'all';
            populateModels();
            modelSelect.value = 'all';
          }
          if (inputId === 'category' || inputId === 'series') {
            populateModels();
            modelSelect.value = 'all';
          }
          form.dispatchEvent(new Event('submit'));
        }
      });
    });

    // Show/hide clear buttons based on URL params (initial)
    for (const [key, value] of urlParams.entries()) {
      const input = form.elements.namedItem(key) as HTMLSelectElement;
      const clearBtn = document.getElementById(`clear-input-${key}`);
      if (input && clearBtn && value !== 'all') {
        clearBtn.classList.remove('hidden');
      }
    }

    // Submit form to update URL
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const url = new URL(window.location.href);
      const formData = new FormData(form);
      for (const [key, value] of formData.entries()) {
        if (value !== 'all') url.searchParams.set(key, value.toString());
        else url.searchParams.delete(key);
      }
      window.location.href = url.toString();
    });
  });
</script>
