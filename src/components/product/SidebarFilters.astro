---
export const prerender = false;
import IconReset from '~/assets/images/icons/reset.svg';
import IconChevronDown from '~/assets/images/icons/chevron-down-select.svg';
import IconClose from '~/assets/images/icons/close.svg';

interface Props {
  data: {
    brands: Array<{ id: string; name: string }>;
    categories: Array<{ id: string; name: string }>;
    series: Array<{ id: string; name: string }>;
    models: string[];
    currentFilters: {
      brand: string;
      category: string;
      series: string;
      model: string;
    };
    totalCount: number;
  };
}

const { data } = Astro.props;
const { brands, categories, series, models, currentFilters, totalCount } = data;
---

<div
  id="sidebar-filter"
  class="fixed lg:relative max-lg:overflow-y-auto shrink-0 inset-y-0 z-50 lg:flex w-full lg:w-80 lg:flex-col max-lg:bg-white transition duration-300 max-lg:opacity-0 max-lg:pointer-events-none"
>
  <div
    class="flex lg:sticky lg:top-8 flex-col gap-y-5 bg-white lg:shadow-md px-6 py-4 relative"
  >
    <button
      id="button-modal-filter-close"
      class="lg:hidden"
      type="button"
      aria-label="Close filter modal"
    >
      <div class="flex justify-end">
        <IconClose class="size-8 bg-gray-800 rounded-full p-1 text-white" />
      </div>
    </button>

    <form id="form-filter" method="get" class="grid grid-cols-1 gap-y-6">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="brand">Brand</label>
          <button id="clear-input-brand" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="brand"
            id="brand"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              brands.map((brand) => (
                <option
                  value={brand.id}
                  selected={currentFilters.brand === brand.id}
                >
                  {brand.name}
                </option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Category -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="category">Category</label>
          <button id="clear-input-category" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="category"
            id="category"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              categories.map((cat) => (
                <option
                  value={cat.id}
                  selected={currentFilters.category === cat.id}
                >
                  {cat.name}
                </option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Series -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="series">Series</label>
          <button id="clear-input-series" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="series"
            id="series"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              series.map((s) => (
                <option value={s.id} selected={currentFilters.series === s.id}>
                  {s.name}
                </option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <!-- Model -->
      <div>
        <div class="flex items-center gap-x-2">
          <label for="model">Model</label>
          <button id="clear-input-model" type="button" class="hidden">
            <IconReset class="size-3 -mt-px" />
          </button>
        </div>
        <div class="grid grid-cols-1">
          <select
            name="model"
            id="model"
            class="appearance-none col-start-1 row-start-1"
          >
            <option value="all">All</option>
            {
              models.map((model) => (
                <option value={model} selected={currentFilters.model === model}>
                  {model}
                </option>
              ))
            }
          </select>
          <IconChevronDown class="icon-chevron-down" />
        </div>
      </div>

      <div class="sticky bottom-0">
        <button type="submit" class="button button-yellow w-full">
          Search <span class="ml-1">({totalCount})</span>
        </button>
      </div>
    </form>
  </div>
</div>

<script>
  document.addEventListener('astro:page-load', function () {
    const form = document.getElementById('form-filter') as HTMLFormElement;
    if (!form) return;

    // Clear buttons: show/hide based on current params
    const urlParams = new URLSearchParams(window.location.search);
    const clearButtons = form.querySelectorAll("button[id^='clear-input-']");
    clearButtons.forEach((button) => {
      const inputId = button.id.replace('clear-input-', '');
      const paramValue = urlParams.get(inputId);
      if (paramValue && paramValue !== 'all') {
        button.classList.remove('hidden');
      }
      button.addEventListener('click', (e) => {
        const input = form.elements.namedItem(inputId) as HTMLSelectElement;
        if (input) {
          input.value = 'all';
          // Submit the form to reload with cleared filter
          form.dispatchEvent(new Event('submit'));
        }
      });
    });

    // Auto-submit when any select changes
    const selects = form.querySelectorAll('select');
    selects.forEach((select) => {
      select.addEventListener('change', () => {
        form.dispatchEvent(new Event('submit'));
      });
    });

    // Override submit to update URL and navigate
    form.addEventListener('submit', (event) => {
      event.preventDefault();
      const url = new URL(window.location.href);
      const formData = new FormData(form);
      for (const [key, value] of formData.entries()) {
        if (value !== 'all') url.searchParams.set(key, value.toString());
        else url.searchParams.delete(key);
      }
      // Reset page to 1 when filters change
      url.searchParams.delete('page');
      window.location.href = url.toString();
    });
  });
</script>
