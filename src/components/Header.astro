---
import { menuMain } from '~/data/menus';
import { fetchData } from '~/services/api';

const rmTrailingSlash = (path: string): string => {
  return path.endsWith('/') && path.length > 1
    ? path.slice(0, path.length - 1)
    : path;
};

const pathname = rmTrailingSlash(Astro.url.pathname);
const companyProfile = await fetchData('company-profile');
---

<header class="sticky top-0 z-40 shadow-sm">
  <!-- Top bar: logo + info -->
  <div class="bg-white border-b border-gray-100">
    <div class="container py-3 lg:py-4">
      <div class="flex justify-between items-center gap-4">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-3 shrink-0">
          <img
            src={companyProfile.logo_url}
            alt={companyProfile.name}
            class="h-8 lg:h-12 w-auto"
          />
          <div class="flex flex-col leading-tight">
            <span class="font-bold text-base lg:text-xl text-gray-900">
              {companyProfile.name}
            </span>
            <span class="text-xs lg:text-sm text-gray-500 hidden sm:block">
              Automation Parts Supplier
            </span>
          </div>
        </a>

        <!-- Info row (desktop) -->
        <div
          class="max-lg:hidden flex items-center gap-8 text-sm text-gray-600"
        >
          <!-- Location -->
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4 text-blue-900 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
              ></path>
            </svg>
            <span>Sidoarjo, Jawa Timur</span>
          </div>

          <!-- Opening hours -->
          <div class="flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4 text-blue-900 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
            </svg>
            <span>Senin – Sabtu, 08:00–16:30</span>
          </div>

          <!-- Email -->
          <a
            href={`mailto:${companyProfile.email}`}
            class="flex items-center gap-2 hover:text-blue-900 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4 text-blue-900 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
              ></path>
            </svg>
            <span>{companyProfile.email}</span>
          </a>

          <!-- WhatsApp CTA -->
          <!-- <a
            href={`https://wa.me/${companyProfile.phone}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-green-500 hover:bg-green-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path>
            </svg>
            {companyProfile.phone}
          </a> -->
        </div>

        <!-- Hamburger (mobile only) -->
        <button
          id="mobile-menu-btn"
          class="lg:hidden flex flex-col justify-center items-center w-10 h-10 gap-1.5 rounded-md hover:bg-gray-100 transition-colors"
          aria-label="Toggle menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-300"
          ></span>
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-300"
          ></span>
          <span class="block w-6 h-0.5 bg-gray-900 transition-all duration-300"
          ></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Bottom bar: nav (desktop only) -->
  <nav
    class="max-lg:hidden bg-blue-950 text-white"
    role="navigation"
    aria-label="Main Navigation"
  >
    <div class="container">
      <div class="flex items-center gap-8">
        {
          menuMain.map((item) => (
            <div class="relative group">
              <a
                href={item.url}
                class={`inline-flex items-center gap-1 py-4 border-b-2 transition text-sm font-medium border-transparent ${
                  pathname === item.url
                    ? 'border-white text-white'
                    : 'hover:border-white/40 hover:text-white text-white/70'
                }`}
                aria-haspopup={item.submenu ? 'true' : 'false'}
              >
                {item.label}
                {item.submenu && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="size-3.5 opacity-60"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M19 9l-7 7-7-7"
                    />
                  </svg>
                )}
              </a>
              {item.submenu && (
                <div
                  class="absolute top-full left-0 z-50 pt-1 w-52 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition duration-200"
                  role="menu"
                >
                  <div class="bg-white rounded-lg ring-1 shadow-lg ring-gray-900/5 overflow-hidden">
                    {item.submenu.map((subItem) => (
                      <a
                        href={subItem.url}
                        class={`block px-4 py-3 text-sm text-gray-700 hover:bg-gray-50 ${pathname === subItem.url ? 'font-bold text-blue-900' : 'font-medium'}`}
                        role="menuitem"
                      >
                        {subItem.label}
                      </a>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))
        }

        <!-- Contact Us -->
        <a
          href={`https://wa.me/${companyProfile.phone}`}
          class={`inline-flex items-center py-4 border-b-2 transition text-sm font-semibold border-transparent ${
            pathname === '/contact'
              ? 'border-white text-white'
              : 'hover:border-white/40 hover:text-white text-white/70'
          }`}
        >
          Contact Us
        </a>
      </div>
    </div>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-0 z-50 invisible"
    aria-hidden="true"
  >
    <div
      id="mobile-menu-backdrop"
      class="absolute inset-0 bg-black/50 opacity-0 transition-opacity duration-300"
    >
    </div>

    <nav
      class="absolute top-0 right-0 h-full w-80 max-w-[90vw] bg-white shadow-2xl translate-x-full transition-transform duration-300 flex flex-col"
      role="navigation"
      aria-label="Mobile Navigation"
    >
      <!-- Drawer header -->
      <div class="flex items-center justify-between px-5 py-4 bg-blue-950">
        <a href="/" class="flex items-center gap-2">
          <img
            src={companyProfile.logo_url}
            alt={companyProfile.name}
            class="h-8 w-auto brightness-0 invert"
          />
          <span class="font-bold text-white text-sm">{companyProfile.name}</span
          >
        </a>
        <button
          id="mobile-menu-close"
          class="w-9 h-9 flex items-center justify-center rounded-md text-white/70 hover:text-white hover:bg-white/10 transition-colors"
          aria-label="Close menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Nav links -->
      <ul class="flex-1 overflow-y-auto py-3 px-3">
        {
          menuMain.map((item) => (
            <li>
              {item.submenu ? (
                <details class="group/details">
                  <summary
                    class={`flex items-center justify-between px-3 py-3 rounded-lg cursor-pointer list-none text-sm font-medium hover:bg-gray-50 transition-colors ${pathname.startsWith(item.url) ? 'text-blue-900 font-bold' : 'text-gray-700'}`}
                  >
                    {item.label}
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="size-4 text-gray-400 transition-transform group-open/details:rotate-180"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </summary>
                  <ul class="mt-1 ml-3 border-l-2 border-gray-100 pl-3 space-y-0.5">
                    {item.submenu.map((subItem) => (
                      <li>
                        <a
                          href={subItem.url}
                          class={`block px-3 py-2.5 rounded-lg text-sm hover:bg-gray-50 transition-colors ${pathname === subItem.url ? 'font-bold text-blue-900' : 'font-medium text-gray-600'}`}
                        >
                          {subItem.label}
                        </a>
                      </li>
                    ))}
                  </ul>
                </details>
              ) : (
                <a
                  href={item.url}
                  class={`block px-3 py-3 rounded-lg text-sm font-medium hover:bg-gray-50 transition-colors ${pathname === item.url ? 'font-bold text-blue-900' : 'text-gray-700'}`}
                >
                  {item.label}
                </a>
              )}
            </li>
          ))
        }

        <!-- Contact Us -->
        <li>
          <a
            href="/contact"
            class={`block px-3 py-3 rounded-lg text-sm font-semibold hover:bg-gray-50 transition-colors ${pathname === '/contact' ? 'text-blue-900' : 'text-gray-700'}`}
          >
            Contact Us
          </a>
        </li>
      </ul>

      <!-- Drawer info + CTA -->
      <div class="px-5 py-5 border-t border-gray-100 space-y-3">
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 text-blue-900 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
            ></path>
          </svg>
          Sidoarjo, Jawa Timur
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-500">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 text-blue-900 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
          </svg>
          Senin – Sabtu, 08:00–16:30
        </div>
        <a
          href={`mailto:${companyProfile.email}`}
          class="flex items-center gap-2 text-xs text-gray-500 hover:text-blue-900 transition-colors"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4 text-blue-900 shrink-0"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="1.5"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
            ></path>
          </svg>
          {companyProfile.email}
        </a>
        <a
          href={`https://wa.me/${companyProfile.phone}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-2 w-full bg-green-500 hover:bg-green-600 text-white font-semibold text-sm px-4 py-3 rounded-lg transition-colors mt-2"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="size-4"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
            ></path>
          </svg>
          {companyProfile.phone}
        </a>
      </div>
    </nav>
  </div>
</header>

<script>
  function initMobileMenu() {
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const drawer = menu?.querySelector('nav');
    const backdrop = document.getElementById('mobile-menu-backdrop');
    const closeBtn = document.getElementById('mobile-menu-close');

    if (!btn || !menu || !drawer || !backdrop) return;

    function openMenu() {
      menu.classList.remove('invisible');
      menu.setAttribute('aria-hidden', 'false');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
      requestAnimationFrame(() => {
        backdrop.classList.add('opacity-100');
        drawer.classList.remove('translate-x-full');
      });
    }

    function closeMenu() {
      backdrop.classList.remove('opacity-100');
      drawer.classList.add('translate-x-full');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
      setTimeout(() => {
        menu.classList.add('invisible');
        menu.setAttribute('aria-hidden', 'true');
      }, 300);
    }

    btn.addEventListener('click', openMenu);
    closeBtn?.addEventListener('click', closeMenu);
    backdrop.addEventListener('click', closeMenu);
    drawer
      .querySelectorAll('a')
      .forEach((link) => link.addEventListener('click', closeMenu));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeMenu();
    });
  }

  initMobileMenu();
  document.addEventListener('astro:after-swap', initMobileMenu);
</script>
