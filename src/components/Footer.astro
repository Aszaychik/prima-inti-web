---
import { siteName } from '~/data/config';
import { menuNavigation } from '~/data/menus';
import NewsletterFooter from './forms/NewsletterFooter.astro';
import { fetchData } from '~/services/api';
import SocialMediaIcons from './SocialMediaIcons.astro';

const year = new Date().getFullYear();
const companyProfile = await fetchData('company-profile');
const marketplaces = companyProfile.external_links ?? [];
---

<footer class="bg-white border-t border-gray-100">
  <!-- Main footer body -->
  <div class="container py-12">
    <div class="grid grid-cols-1 md:grid-cols-[2fr_1fr_1fr] gap-12">
      <!-- Brand + contact column -->
      <div class="flex flex-col gap-5">
        <a href="/" class="inline-flex items-center gap-3 group w-fit">
          <img
            src={companyProfile.logo_url}
            alt={companyProfile.name}
            class="h-10 w-auto object-contain"
          />
          <span
            class="font-bold text-lg text-gray-900 group-hover:text-gray-600 transition-colors"
          >
            {companyProfile.name}
          </span>
        </a>

        <ul class="flex flex-col gap-3 text-sm text-gray-500">
          {
            companyProfile.phone && (
              <li>
                <a
                  href={`tel:${companyProfile.phone}`}
                  class="inline-flex items-start gap-2.5 hover:text-gray-800 transition-colors"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="size-4 mt-0.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z"
                    />
                  </svg>
                  {companyProfile.phone}
                </a>
              </li>
            )
          }
          {
            companyProfile.email && (
              <li>
                <a
                  href={`mailto:${companyProfile.email}`}
                  class="inline-flex items-start gap-2.5 hover:text-gray-800 transition-colors"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="size-4 mt-0.5 shrink-0"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75"
                    />
                  </svg>
                  {companyProfile.email}
                </a>
              </li>
            )
          }
          {
            companyProfile.address && (
              <li class="inline-flex items-start gap-2.5">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="size-4 mt-0.5 shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"
                  />
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
                  />
                </svg>
                <span class="leading-relaxed">{companyProfile.address}</span>
              </li>
            )
          }
        </ul>

        <div class="flex gap-3">
          <SocialMediaIcons />
        </div>
      </div>

      <!-- Navigation column -->
      {
        menuNavigation.items.length > 0 && (
          <div>
            <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase mb-5">
              {menuNavigation.prettyName}
            </p>
            <ul class="space-y-3">
              {menuNavigation.items.map((item) => (
                <li>
                  <a
                    href={item.url}
                    class="text-sm text-gray-600 hover:text-gray-900 transition-colors"
                  >
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <!-- Marketplaces column (from external_links) -->
      {
        marketplaces.length > 0 && (
          <div>
            <p class="text-xs font-semibold tracking-widest text-gray-400 uppercase mb-5">
              Find us on
            </p>
            <div class="flex flex-wrap gap-3">
              {marketplaces.map((item) => (
                <a
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center bg-gray-50 hover:bg-gray-100 border border-gray-200 rounded-lg px-3 py-2 transition-colors"
                  title={item.platform}
                >
                  <img
                    src={item.logo_url}
                    alt={item.platform}
                    class="h-6 w-auto object-contain"
                    loading="lazy"
                  />
                </a>
              ))}
            </div>
          </div>
        )
      }
    </div>
  </div>

  <!-- Newsletter bar -->
  <div class="border-t border-gray-100">
    <div class="container py-8">
      <div
        class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
      >
        <div>
          <p class="font-semibold text-gray-900">Stay in the loop</p>
          <p class="text-sm text-gray-500 mt-0.5">
            Product updates and news, straight to your inbox.
          </p>
        </div>
        <div class="shrink-0">
          <NewsletterFooter />
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-100">
    <div class="container py-5">
      <p class="text-sm text-gray-400 text-center">
        &copy; {year}
        {siteName}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
