---
import { Image } from 'astro:assets';
import Layout from '~/layouts/Layout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
import Button from '~/components/Button.astro';
import Hero from '~/components/Hero.astro';
import Faq from '~/components/Faq.astro';
import Heading from '~/components/Heading.astro';
import WidgetSearch from '~/components/WidgetSearch.astro';
import Grid from '~/components/Grid.astro';
import GridItem from '~/components/GridItem.astro';
import Stats from '~/components/Stats.astro';

// Images
import ImageCarDealer from '~/assets/images/pexels-shkrabaanthony-7144179.jpg';
import ImageHeadingBackground from '~/assets/images/pexels-fox-58267-26510348.jpg';
import ShowProducts from '~/components/ShowProducts.astro';
import ImageOne from '~/assets/images/pexels-leif-bergerson-99376750-9764731.webp';
import ImageTwo from '~/assets/images/pexels-zenzazione-2922140.webp';

// SEO meta description
const metaDescription =
  'Prima Inti Electrical – distributor of quality electrical components, plus professional installation, maintenance, and consulting services. Trusted by industry and home users.';
---

<Layout pageTitle="Home" metaDescription={metaDescription}>
  {/* Main Heading */}
  <Section class:list={'relative'}>
    <Image
      src={ImageHeadingBackground}
      alt="Electrical equipment and tools"
      class:list={'absolute inset-0 w-full h-full object-cover'}
    />
    <div class="absolute inset-0 w-full h-full object-cover bg-gray-800/80">
    </div>
    <Container class:list={'relative z-10'}>
      <Heading class:list={'prose-invert max-w-4xl'}>
        <h1 slot="heading-title" class="mb-0 lg:text-7xl text-balance">
          Electrical Products & Professional Services
        </h1>
        <p slot="heading-content">
          From circuit breakers to complete panel builds – we supply and service
          everything electrical. Browse our catalog or let our experts help you
          find the right solution for your project.
        </p>
      </Heading>
      <WidgetSearch />
    </Container>
  </Section>

  {/* Hero */}
  <Section>
    <Container>
      <Hero>
        <div slot="hero-left" class="prose lg:max-w-2xl">
          <h2>Quality components, expert service</h2>
          <p>
            Prima Inti Electrical has been delivering reliable electrical
            products and professional services for over 20 years. We serve
            industrial, commercial, and residential clients – offering
            everything from distribution panels, cables, and switchgear to
            lighting, automation devices, and safety equipment.
          </p>

          <Button href="/products" class:list={'mt-4'}>View all products</Button
          >
        </div>
        <div slot="hero-right">
          <Image
            src={ImageCarDealer}
            alt="Electrical engineer inspecting a panel"
          />
        </div>
      </Hero>
    </Container>
  </Section>

  {/* Grid */}
  <Section>
    <Container>
      <Grid>
        <GridItem
          image={ImageOne}
          imageAlt="Industrial electrical panel"
          span={2}
          link="/products"
          As="a"
          xl
        >
          <h2>Featured products</h2>
          <p>
            Discover our most‑requested electrical components: compact circuit
            breakers, energy meters, industrial sockets, surge protection
            devices, and more. All items meet international safety standards and
            come with full technical support.
          </p>
          <Button
            As="button"
            type="button"
            color="white-outline"
            class:list={'mt-4 group-hover:bg-white/10'}>View catalog</Button
          >
        </GridItem>

        <GridItem
          image={ImageTwo}
          imageAlt="Technician performing maintenance"
          link="/services"
          As="a"
        >
          <h3>Professional services</h3>
          <p>
            Need more than just products? Our certified electricians offer
            installation, preventive maintenance, fault diagnosis, and system
            upgrades – for factories, office buildings, and homes.
          </p>
          <Button
            As="button"
            type="button"
            color="white-outline"
            class:list={'mt-4 group-hover:bg-white/10'}>Request a quote</Button
          >
        </GridItem>

        <GridItem>
          <h3>Custom solutions</h3>
          <p>
            Don't see what you need? We design and assemble custom distribution
            boards, control panels, and automation systems tailored to your
            exact specifications.
          </p>
        </GridItem>
      </Grid>
    </Container>
  </Section>

  {/* Hero */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Hero invert>
        <div slot="hero-left" class="prose lg:max-w-2xl">
          <h2>Why choose Prima Inti Electrical?</h2>
          <p>
            We combine decades of technical expertise with a customer‑first
            approach. Every product is sourced from reputable manufacturers, and
            every service is performed by licensed professionals. We offer fast
            delivery and 24/7 emergency support.
          </p>
        </div>
        <div slot="hero-right">
          <Image src={ImageCarDealer} alt="Team of electrical engineers" />
        </div>
      </Hero>
    </Container>
  </Section>

  {/* Cars - keep as is for now but change section heading */}
  <Section class:list={'bg-blue-50'}>
    <Container>
      <Heading>
        <h2 slot="heading-title" class="mb-0">
          Bestselling electrical components
        </h2>
        <p slot="heading-content">
          Explore our top‑rated products – used by electricians and engineers
          who demand reliability and performance.
        </p>
      </Heading>
      <ShowProducts
        slugs={[
          '954c1cf4-4b08-4c75-8d8a-00e68732dc28',
          'ca96749c-e467-45c5-bbbb-5ee0f6961a33',
          'bbdb3a0c-51e5-4cb4-b4f8-b6678559eb94',
        ]}
      />
    </Container>
  </Section>

  {/* Stats */}
  <Section>
    <Container>
      <Heading class:list={'text-center mx-auto'}>
        <h2 slot="heading-title" class="text-balance">
          Serving industry and homes since 2002
        </h2>
        <p slot="heading-content">
          Our numbers speak for themselves – and they keep growing thanks to our
          loyal customers.
        </p>
      </Heading>

      <Stats
        items={[
          {
            title: 'Products in stock',
            value: '3500+',
            animateNumber: true,
            animateFrom: 2000,
          },
          {
            title: 'Satisfied customers',
            value: '1250+',
            animateNumber: true,
            animateFrom: 800,
          },
          {
            title: 'Years of experience',
            value: '22+',
          },
        ]}
      />
    </Container>
  </Section>

  {/* CTA */}
  <Section class:list={'bg-gradient-to-br from-gray-900 to-gray-700'}>
    <Container>
      <Heading class:list={'mb-0 lg:mb-0 prose-invert text-center mx-auto'}>
        <h2 slot="heading-title">Need a custom solution or urgent service?</h2>

        <p slot="heading-content">
          Our technical team is ready to advise you – whether you need a single
          component, a full panel build, or an emergency repair. Contact us
          today for a free consultation.
        </p>

        <Button href="/contact" color="white" class:list={'mt-8'}
          >Contact our experts</Button
        >
      </Heading>
    </Container>
  </Section>

  {/* Cars - recent products section */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Heading>
        <h2 slot="heading-title" class="mb-0">Recently added products</h2>
        <p slot="heading-content">
          Check out the latest electrical components we've added to our
          inventory – new arrivals every month.
        </p>
      </Heading>
      <ShowProducts recent={true} ui="grid" />
    </Container>
  </Section>

  {/* FAQ */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Heading class:list={'max-w-3xl mx-auto lg:text-center'}>
        <h2 slot="heading-title">Frequently asked questions</h2>

        <p slot="heading-content">
          Everything you need to know about our products, services, and ordering
          process.
        </p>
      </Heading>

      <Faq
        items={[
          {
            question: 'Do you sell both retail and wholesale?',
            answer:
              'Yes. We serve homeowners, electricians, contractors, and industrial buyers. Volume discounts are available for bulk orders.',
          },
          {
            question: 'Can you install the products I buy from you?',
            answer:
              'Absolutely. Our licensed electricians can handle installation, testing, and commissioning – saving you time and ensuring compliance with safety codes.',
          },
          {
            question: 'What brands do you carry?',
            answer:
              'We stock leading brands such as Schneider Electric, ABB, Siemens, Legrand, and many others. Contact us for specific brand requests.',
          },
          {
            question: 'Do you offer emergency repair services?',
            answer:
              'Yes – we have a 24/7 emergency hotline for critical breakdowns. Our team will be on site as quickly as possible.',
          },
        ]}
      />
    </Container>
  </Section>
</Layout>
