<script>
  let bannerCleanup = null;
  let brandsCleanup = null;

  // ── Banner carousel ─────────────────────────────────────────────────────────
  function initBannerCarousel() {
    if (bannerCleanup) {
      bannerCleanup();
      bannerCleanup = null;
    }

    const track = document.getElementById('carousel-track');
    const prevBtn = document.getElementById('carousel-prev');
    const nextBtn = document.getElementById('carousel-next');
    const dots = document.querySelectorAll('.carousel-dot');
    const carousel = document.getElementById('banner-carousel');
    const viewport = track?.parentElement; // the overflow-hidden div

    if (!track || !viewport) return;

    const totalSlides = track.children.length;
    let currentIndex = 0;
    let timer = null;

    // KEY FIX: use px not % —
    // translateX(%) is relative to the element's OWN width (= all slides combined),
    // so -100% overshoots by totalSlides×. Pixels use the visible container width.
    function slideWidth() {
      return viewport.offsetWidth;
    }

    function goTo(index) {
      currentIndex = (index + totalSlides) % totalSlides;
      track.style.transform = `translateX(-${currentIndex * slideWidth()}px)`;
      dots.forEach((dot, i) => {
        dot.classList.toggle('bg-white', i === currentIndex);
        dot.classList.toggle('bg-white/40', i !== currentIndex);
      });
    }

    function next() {
      goTo(currentIndex + 1);
    }
    function prev() {
      goTo(currentIndex - 1);
    }
    function stopAuto() {
      if (timer) {
        clearInterval(timer);
        timer = null;
      }
    }
    function startAuto() {
      stopAuto();
      timer = setInterval(next, 5000);
    }

    // Re-snap to correct position on window resize
    const onResize = () => goTo(currentIndex);
    window.addEventListener('resize', onResize);

    prevBtn?.addEventListener('click', () => {
      prev();
      startAuto();
    });
    nextBtn?.addEventListener('click', () => {
      next();
      startAuto();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        goTo(i);
        startAuto();
      });
    });

    carousel?.addEventListener('mouseenter', stopAuto);
    carousel?.addEventListener('mouseleave', startAuto);

    // Touch swipe
    let touchStartX = 0;
    carousel?.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = e.touches[0].clientX;
      },
      { passive: true },
    );
    carousel?.addEventListener(
      'touchend',
      (e) => {
        const diff = touchStartX - e.changedTouches[0].clientX;
        if (Math.abs(diff) > 40) {
          diff > 0 ? next() : prev();
          startAuto();
        }
      },
      { passive: true },
    );

    goTo(0);
    startAuto();

    bannerCleanup = () => {
      stopAuto();
      window.removeEventListener('resize', onResize);
      carousel?.removeEventListener('mouseenter', stopAuto);
      carousel?.removeEventListener('mouseleave', startAuto);
    };
  }

  // ── Brands marquee ──────────────────────────────────────────────────────────
  function initBrandsMarquee() {
    if (brandsCleanup) {
      brandsCleanup();
      brandsCleanup = null;
    }

    const track = document.getElementById('brands-carousel-track');
    const container = document.getElementById('brands-carousel-container');
    if (!track || !container) return;

    let raf = null;
    let isPaused = false;
    let translate = 0;
    let halfWidth = 0;
    const speed = 0.5;

    function measure() {
      halfWidth = track.scrollWidth / 2;
    }

    function step() {
      if (!isPaused && halfWidth > 0) {
        translate -= speed;
        if (Math.abs(translate) >= halfWidth) translate += halfWidth;
        track.style.transform = `translateX(${translate}px)`;
      }
      raf = requestAnimationFrame(step);
    }

    const pause = () => {
      isPaused = true;
    };
    const resume = () => {
      isPaused = false;
    };

    container.addEventListener('mouseenter', pause);
    container.addEventListener('mouseleave', resume);

    if (document.readyState === 'complete') {
      measure();
    } else {
      window.addEventListener('load', measure, { once: true });
    }
    setTimeout(measure, 300);

    raf = requestAnimationFrame(step);

    brandsCleanup = () => {
      if (raf) {
        cancelAnimationFrame(raf);
        raf = null;
      }
      container.removeEventListener('mouseenter', pause);
      container.removeEventListener('mouseleave', resume);
    };
  }

  // ── Bootstrap ───────────────────────────────────────────────────────────────
  function init() {
    initBannerCarousel();
    initBrandsMarquee();
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
