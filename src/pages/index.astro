---
import { Image } from 'astro:assets';
import Layout from '~/layouts/Layout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
import Button from '~/components/Button.astro';
import Hero from '~/components/Hero.astro';
import Faq from '~/components/Faq.astro';
import Heading from '~/components/Heading.astro';
import WidgetSearch from '~/components/WidgetSearch.astro';
import Grid from '~/components/Grid.astro';
import GridItem from '~/components/GridItem.astro';
import Stats from '~/components/Stats.astro';
import ShowProducts from '~/components/ShowProducts.astro';
import { fetchData } from '~/services/api';

// Images
import ImageHeadingBackground from '~/assets/images/pexels-fox-58267-26510348.jpg';
import ImageOne from '~/assets/images/pexels-freek-wolsink-508219-34194580.jpg';
import ImageTwo from '~/assets/images/pexels-pixabay-159201.jpg';

const companyProfile = await fetchData('company-profile');

const metaDescription =
  'CV PRIMA INTI VANINDO – solusi otomasi industri, penjualan komponen, perbaikan, dan pemrograman sistem. Terpercaya untuk pabrik dan perusahaan di Indonesia.';
---

<Layout pageTitle="Beranda" metaDescription={metaDescription}>
  {/* Main Heading */}
  <Section class:list={'relative'}>
    <Image
      src={ImageHeadingBackground}
      alt="Peralatan dan perkakas listrik"
      class:list={'absolute inset-0 w-full h-full object-cover'}
    />
    <div class="absolute inset-0 w-full h-full object-cover bg-gray-800/80">
    </div>
    <Container class:list={'relative z-10'}>
      <Heading class:list={'prose-invert max-w-4xl'}>
        <h1 slot="heading-title" class="mb-0 lg:text-7xl text-balance">
          Solusi Otomasi Industri Terpercaya
        </h1>
        <p slot="heading-content">
          Mitra andal Anda untuk layanan perbaikan, penjualan, dan pemrograman
          sistem industri – dari servo drive, inverter, PLC, HMI, hingga panel
          kontrol. Lihat katalog produk atau konsultasikan kebutuhan proyek Anda
          dengan tim teknis kami.
        </p>
      </Heading>
      <WidgetSearch />
    </Container>
  </Section>

  {/* Hero */}
  <Section>
    <Container>
      <Hero>
        <div slot="hero-left" class="prose lg:max-w-2xl">
          <h2>Komponen berkualitas, layanan ahli</h2>
          <p>
            CV PRIMA INTI VANINDO telah memberikan solusi otomasi industri dan
            layanan profesional selama lebih dari 10 tahun. Kami melayani klien
            industri, komersial, dan residensial – menyediakan inverter, servo
            drive, PLC, HMI, panel listrik, dan berbagai komponen sistem
            kontrol.
          </p>
          <Button href="/products" class:list={'mt-4'}>
            Lihat semua produk
          </Button>
        </div>

        <div slot="hero-right">
          <Stats
            items={[
              { title: 'Tahun pengalaman', value: '10+' },
              { title: 'Brand ternama', value: '15+' },
              { title: 'Kategori produk', value: '25+' },
            ]}
          />
        </div>
      </Hero>
    </Container>
  </Section>

  {/* Grid */}
  <Section>
    <Container>
      <Grid>
        <GridItem
          image={ImageOne}
          imageAlt="Panel kontrol industri"
          span={2}
          link="/products"
          As="a"
          xl
        >
          <h2>Produk unggulan</h2>
          <p>
            Temukan komponen otomasi industri terpopuler: servo drive, inverter,
            PLC, HMI, modul kontrol, dan perangkat proteksi. Semua produk
            memenuhi standar internasional dengan dukungan teknis penuh.
          </p>
          <Button
            As="button"
            type="button"
            color="white-outline"
            class:list={'mt-4 group-hover:bg-white/10'}>Lihat katalog</Button
          >
        </GridItem>

        <GridItem
          image={ImageTwo}
          imageAlt="Teknisi sedang melakukan perawatan"
          link="/services"
          As="a"
        >
          <h3>Layanan profesional</h3>
          <p>
            Perbaikan, instalasi, pemeliharaan preventif, diagnosis kerusakan,
            dan upgrade sistem – untuk pabrik, gedung perkantoran, dan rumah.
          </p>
          <Button
            As="button"
            type="button"
            color="white-outline"
            class:list={'mt-4 group-hover:bg-white/10'}>Ajukan penawaran</Button
          >
        </GridItem>

        <GridItem As="a" link="#contact">
          <h3>Tidak menemukan yang dicari?</h3>
          <p>
            Hubungi kami langsung — tim kami siap membantu Anda menemukan
            komponen yang tepat.
          </p>
          <span
            class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-gray-300 group-hover:text-gray-500 transition-colors"
          >
            Hubungi kami
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M8.25 4.5l7.5 7.5-7.5 7.5"></path>
            </svg>
          </span>
        </GridItem>
      </Grid>
    </Container>
  </Section>

  {/* Hero invert */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Hero invert>
        <div slot="hero-left" class="prose lg:max-w-2xl">
          <h2>Mengapa memilih CV PRIMA INTI VANINDO?</h2>
          <p>
            Kami menggabungkan pengalaman teknis puluhan tahun dengan pendekatan
            yang mengutamakan kepuasan pelanggan. Setiap produk berasal dari
            pabrikan ternama, dan setiap layanan dilakukan oleh tenaga ahli
            bersertifikat. Kami menawarkan pengiriman cepat dan dukungan darurat
            24/7.
          </p>
        </div>

        <div
          slot="hero-right"
          class="w-full h-full min-h-72 lg:min-h-96 rounded-xl overflow-hidden shadow-md"
        >
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d247.2871354180878!2d112.73373930128474!3d-7.399286905095954!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2dd7e5ea56cacf65%3A0xae5c4ace5f2b4eaf!2sPT.SAIN%20ASIA%20PRIMA!5e0!3m2!1sen!2sus!4v1779240019888!5m2!1sen!2sus"
            width="100%"
            height="100%"
            style="border:0; min-height: 380px;"
            allowfullscreen
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lokasi CV Prima Inti Vanindo"></iframe>
          <a
            href="https://maps.app.goo.gl/H83TiRYQ5QEPpWfS6"
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="size-4 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="1.5"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z"
              ></path>
            </svg>
            Buka di Google Maps
          </a>
        </div>
      </Hero>
    </Container>
  </Section>

  {/* Featured products */}
  <Section class:list={'bg-blue-50'}>
    <Container>
      <Heading>
        <h2 slot="heading-title" class="mb-0">Produk otomasi terlaris</h2>
        <p slot="heading-content">
          Produk pilihan kami – digunakan oleh teknisi dan insinyur yang
          mengandalkan keandalan dan performa.
        </p>
      </Heading>
      <ShowProducts
        slugs={[
          '954c1cf4-4b08-4c75-8d8a-00e68732dc28',
          'ca96749c-e467-45c5-bbbb-5ee0f6961a33',
          'bbdb3a0c-51e5-4cb4-b4f8-b6678559eb94',
        ]}
      />
    </Container>
  </Section>

  {/* CTA */}
  <Section
    id="contact"
    class:list={'bg-gradient-to-br from-gray-900 to-gray-700'}
  >
    <Container>
      <Heading class:list={'mb-0 lg:mb-0 prose-invert text-center mx-auto'}>
        <h2 slot="heading-title">Butuh bantuan memilih produk?</h2>
        <p slot="heading-content">
          Tim kami siap membantu — baik Anda membutuhkan satu komponen maupun
          pengadaan dalam jumlah besar. Chat langsung via WhatsApp untuk respons
          cepat.
        </p>
        <a
          slot="heading-content"
          href={`https://wa.me/${companyProfile.phone}`}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-3 bg-white hover:bg-gray-100 text-gray-900 font-semibold px-6 py-3 rounded-lg transition-colors"
        >
          <img
            src="https://cdn.brandfetch.io/id6Zq084G_/w/800/h/516/theme/dark/id07h05Ur1.png?c=1dxbfHSJFAPEGdCLU4o5B"
            alt="WhatsApp"
            class="h-5 w-auto object-contain"
            loading="lazy"
          />
          Chat via WhatsApp
        </a>
      </Heading>
    </Container>
  </Section>

  {/* Recent products */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Heading>
        <h2 slot="heading-title" class="mb-0">Produk terbaru</h2>
        <p slot="heading-content">
          Komponen otomasi terbaru yang kami tambahkan ke inventaris – setiap
          bulan ada produk baru.
        </p>
      </Heading>
      <ShowProducts recent={true} ui="grid" />
    </Container>
  </Section>

  {/* FAQ */}
  <Section class:list={'bg-gray-50'}>
    <Container>
      <Heading class:list={'max-w-3xl mx-auto lg:text-center'}>
        <h2 slot="heading-title">Pertanyaan yang sering diajukan</h2>
        <p slot="heading-content">
          Semua yang perlu Anda ketahui tentang produk, layanan, dan cara
          pemesanan.
        </p>
      </Heading>
      <Faq
        items={[
          {
            question: 'Apakah Anda menjual eceran dan grosir?',
            answer:
              'Ya. Kami melayani pemilik rumah, teknisi listrik, kontraktor, dan pembeli industri. Diskon volume tersedia untuk pesanan dalam jumlah besar.',
          },
          {
            question: 'Bisakah Anda memasang produk yang saya beli?',
            answer:
              'Tentu. Teknisi listrik bersertifikat kami dapat melakukan instalasi, pengujian, dan komisioning – menghemat waktu Anda dan memastikan kepatuhan terhadap standar keselamatan.',
          },
          {
            question: 'Merek apa saja yang Anda sediakan?',
            answer:
              'Kami menyediakan merek-merek terkemuka seperti ABB, Siemens, Schneider Electric, Mitsubishi Electric, Yaskawa, Omron, Allen Bradley, Danfoss, Lenze, Fanuc, Eaton dan lainnya. Hubungi kami untuk permintaan merek tertentu.',
          },
          {
            question: 'Apakah Anda menyediakan layanan perbaikan darurat?',
            answer:
              'Ya – kami memiliki hotline darurat 24/7 untuk kerusakan kritis. Tim kami akan segera datang ke lokasi.',
          },
        ]}
      />
    </Container>
  </Section>
</Layout>
