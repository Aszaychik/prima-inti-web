---
import AuthLayout from '~/layouts/AuthLayout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
---

<AuthLayout pageTitle="Dashboard">
  <Section>
    <Container>
      <div
        id="dashboard-content"
        class="max-w-4xl mx-auto bg-white p-8 rounded shadow-md hidden"
      >
        <h1 class="text-2xl font-bold mb-6">Dashboard</h1>
        <p class="text-green-600">
          ✅ Login successful! You are now viewing the dashboard.
        </p>
        <p class="mt-4 text-gray-600">
          This is a simple placeholder. You can add admin features here later.
        </p>
      </div>
      <div
        id="login-prompt"
        class="max-w-md mx-auto bg-white p-8 rounded shadow-md text-center"
      >
        <p class="text-red-600 mb-4">You are not logged in.</p>
        <a
          href="/auth/login"
          class="bg-yellow-200 px-4 py-2 rounded inline-block">Go to Login</a
        >
      </div>
    </Container>
  </Section>
</AuthLayout>

<script>
  import { isAuthenticated } from '~/services/auth';

  const dashboardDiv = document.getElementById('dashboard-content');
  const loginPromptDiv = document.getElementById('login-prompt');

  if (isAuthenticated()) {
    dashboardDiv.classList.remove('hidden');
    loginPromptDiv.classList.add('hidden');
  } else {
    dashboardDiv.classList.add('hidden');
    loginPromptDiv.classList.remove('hidden');
  }
</script>
