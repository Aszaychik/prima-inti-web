---
import Layout from '~/layouts/Layout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
import { fetchData } from '~/services/api';
import IconLogo from '~/assets/images/icons/logo.svg';
import ButtonGoBack from '~/components/buttons/ButtonGoBack.astro';
import ButtonInquire from '~/components/buttons/ButtonInquire.astro';
import { generateProductSlug, extractIdFromSlug, isCanonicalSlug } from '~/utils/slug';

export const prerender = false;

const { slug } = Astro.params;

// Extract UUID from slug param (works for both old pure-UUID links and new slug+id links)
const id = extractIdFromSlug(slug ?? '');

if (!id) {
  return new Response(null, { status: 404, statusText: 'Product not found' });
}

const companyProfile = await fetchData('company-profile');

let product = null;
let error = null;

try {
  const response = await fetchData(`products/${id}`);
  product = response.data || response;
  if (!product || Object.keys(product).length === 0) {
    error = 'Product not found';
  }
} catch (err) {
  console.error(err);
  error = 'Failed to load product';
}

if (error || !product) {
  return new Response(null, { status: 404, statusText: 'Product not found' });
}

// Build canonical slug for this product
const canonicalSlug = generateProductSlug(product.model, product.id);

// If accessed via old pure-UUID link, 301 redirect to the new SEO-friendly slug URL
if (!isCanonicalSlug(slug ?? '')) {
  return Astro.redirect(`/products/${canonicalSlug}`, 301);
}

const formatIDR = (value) => {
  if (!value && value !== 0) return null;
  return value.toLocaleString('id-ID');
};

const stripHtml = (html: string) => html?.replace(/<[^>]*>/g, '').trim() ?? '';

const plainDescription = product.description_html
  ? stripHtml(product.description_html).slice(0, 160)
  : product.description?.slice(0, 160);

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.model,
  description: plainDescription,
  brand: { '@type': 'Brand', name: product.brand?.name ?? '' },
  ...(product.image_url && { image: product.image_url }),
  ...(product.category?.name && { category: product.category.name }),
  offers: {
    '@type': 'Offer',
    priceCurrency: 'IDR',
    ...(product.salePrice || product.price
      ? { price: product.salePrice || product.price }
      : {}),
    availability:
      product.stock > 0
        ? 'https://schema.org/InStock'
        : 'https://schema.org/OutOfStock',
    seller: { '@type': 'Organization', name: 'CV Prima Inti Vanindo' },
  },
};
---

<Layout
  pageTitle={`${product.model} | ${product.brand?.name || 'Product'}`}
  description={plainDescription}
  ogImage={product.image_url}
  schema={productSchema}
>
  <Section class:list="bg-gray-50">
    <Container class:list="pb-0 lg:pb-0 max-sm:pt-8 print:hidden">
      <ButtonGoBack />
    </Container>

    <Container class:list="pt-0 lg:pt-0 max-md:max-w-full max-md:px-0">
      <div class="bg-white shadow-md">
        <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">

          <!-- Image gallery -->
          <div id="gallery-wrapper" class="relative">
            {
              product.image_url ? (
                <img
                  src={product.image_url}
                  alt={`${product.model} – ${product.brand?.name ?? ''}`}
                  class="w-full h-auto object-contain"
                  loading="eager"
                />
              ) : (
                <div class="inset-0 text-gray-200 size-full bg-gray-50 flex flex-col gap-4 items-center justify-center min-h-96">
                  <IconLogo class="h-24" />
                  <span class="text-gray-400 select-none font-bold italic">No image</span>
                </div>
              )
            }
          </div>

          <!-- Product info -->
          <div class="p-4 lg:p-8 flex flex-col items-start h-full">

            <!-- Title & series -->
            <div class="mb-4 lg:mb-6">
              <h1 class="h4">{product.model}</h1>
              {
                product.series?.name && (
                  <span class="text-base text-gray-600">
                    Series: {product.series.name}
                  </span>
                )
              }
            </div>

            <hr class="w-full border-gray-200" />

            <!-- Price & stock -->
            <div class="my-4">
              {
                product.salePrice ? (
                  <>
                    <span class="text-gray-400 line-through text-lg">
                      Rp{formatIDR(product.price)}
                    </span>
                    <span class="text-2xl font-bold text-green-600 ml-3">
                      Rp{formatIDR(product.salePrice)}
                    </span>
                  </>
                ) : product.price ? (
                  <span class="text-2xl font-bold text-green-600">
                    Rp{formatIDR(product.price)}
                  </span>
                ) : (
                  <div class="flex flex-col gap-2">
                    <span class="text-gray-500 italic">Hubungi kami untuk harga</span>
                    <a
                      href={`https://wa.me/${companyProfile.phone}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-green-600 hover:text-green-700 font-medium transition-colors w-fit"
                    >
                      <!-- WhatsApp icon -->
                      <svg xmlns="http://www.w3.org/2000/svg" class="size-5 shrink-0" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                      </svg>
                      {companyProfile.phone}
                    </a>
                  </div>
                )
              }
              <p class={`text-sm mt-1 ${product.stock > 0 ? 'text-green-600' : 'text-red-600'}`}>
                {product.stock > 0 ? `Stok: ${product.stock}` : 'Stok habis'}
              </p>
            </div>

            <hr class="w-full border-gray-200" />

            <!-- Specifications -->
            <div class="mt-4 w-full">
              <h2 class="h6">Spesifikasi</h2>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 mt-2 text-sm">
                <li><strong>Brand:</strong> {product.brand?.name || '—'}</li>
                <li><strong>Kategori:</strong> {product.category?.name || '—'}</li>
                <li><strong>Series:</strong> {product.series?.name || '—'}</li>
                <li><strong>Model:</strong> {product.model}</li>
              </ul>
            </div>

            <hr class="w-full border-gray-200 mt-4" />

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-x-4 mt-8 w-full max-sm:gap-y-8 print:hidden">
              <div class="flex items-center max-sm:justify-center gap-x-4 w-full">
                <ButtonInquire companyProfile={companyProfile} />
              </div>
            </div>
          </div>
        </div>

        <!-- Description -->
        {
          (product.description_html || product.description) && (
            <div class="p-4 lg:p-8 border-t border-gray-200">
              <h2 class="h6 mb-4">Deskripsi Produk</h2>
              <div
                class="prose prose-sm prose-headings:font-semibold prose-headings:text-gray-800 prose-li:marker:text-blue-900 prose-strong:text-gray-800 max-w-none text-gray-600"
                set:html={product.description_html || `<p>${product.description}</p>`}
              />
            </div>
          )
        }
      </div>
    </Container>
  </Section>
</Layout>

<script>
  document.addEventListener('astro:page-load', () => {});
</script>