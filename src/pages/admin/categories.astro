---
import AuthLayout from '~/layouts/AuthLayout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
import Search from '~/components/admin/Search.astro';
---

<AuthLayout pageTitle="Manage Categories">
  <Section>
    <Container>
      <div class="bg-white rounded shadow p-6">
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-2xl font-bold">Categories</h1>
          <div class="flex items-center gap-3">
            <Search placeholder="Search categories..." id="admin-search" />

            <button
              id="create-category-btn"
              class="bg-green-600 text-white px-4 py-1 rounded hover:bg-green-700"
              >+</button
            >
          </div>
        </div>

        <!-- Table container -->
        <div id="categories-table" class="overflow-x-auto">
          <table class="min-w-full border">
            <thead>
              <tr>
                <th class="border px-4 py-2">ID</th>
                <th class="border px-4 py-2">Name</th>
                <th class="border px-4 py-2">Description</th>
                <th class="border px-4 py-2">Created At</th>
                <th class="border px-4 py-2">Actions</th>
              </tr>
            </thead>
            <tbody id="categories-tbody">
              <tr><td colspan="5" class="text-center py-4">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </Container>

    <!-- Modal for create/edit -->
    <div
      id="category-modal"
      class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50"
    >
      <div class="bg-white rounded-lg p-6 w-full max-w-md">
        <h2 id="modal-title" class="text-xl font-bold mb-4">Add Category</h2>
        <form id="category-form">
          <input type="hidden" id="category-id" />
          <div class="mb-4">
            <label class="block mb-1">Name</label>
            <input
              type="text"
              id="category-name"
              required
              class="w-full border px-3 py-2 rounded"
            />
          </div>
          <div class="mb-4">
            <label class="block mb-1">Description</label>
            <textarea
              id="category-description"
              rows="3"
              class="w-full border px-3 py-2 rounded"></textarea>
          </div>
          <div class="flex justify-end gap-2">
            <button
              type="button"
              id="modal-close"
              class="px-4 py-2 border rounded">Cancel</button
            >
            <button
              type="submit"
              class="bg-blue-600 text-white px-4 py-2 rounded">Save</button
            >
          </div>
        </form>
      </div>
    </div>

    <script>
      document.addEventListener('admin:search', (e) => {
        const query = e.detail.query;
        document.querySelectorAll('#categories-tbody tr').forEach((row) => {
          const text = row.textContent.toLowerCase();
          row.style.display = text.includes(query) ? '' : 'none';
        });
      });

      import { get, post, put, del } from '~/services/api';

      let currentEditId = null;

      async function loadCategories() {
        const tbody = document.getElementById('categories-tbody');
        tbody.innerHTML =
          '<tr><td colspan="5" class="text-center py-4">Loading...</td></tr>';
        try {
          const response = await get('categories');
          const categories = response.data || [];
          if (categories.length === 0) {
            tbody.innerHTML =
              '<tr><td colspan="5" class="text-center py-4">No categories found.</td></tr>';
            return;
          }
          tbody.innerHTML = categories
            .map(
              (cat) => `
              <tr>
                <td class="border px-4 py-2">${cat.id}</td>
                <td class="border px-4 py-2">${escapeHtml(cat.name)}</td>
                <td class="border px-4 py-2">${escapeHtml(cat.description) || '-'}</td>
                <td class="border px-4 py-2">${new Date(cat.created_at).toLocaleDateString()}</td>
                <td class="border px-4 py-2">
                  <button class="edit-btn text-blue-600 mr-2" data-id="${cat.id}" data-name="${escapeHtml(cat.name)}" data-description="${escapeHtml(cat.description || '')}">Edit</button>
                  <button class="delete-btn text-red-600" data-id="${cat.id}">Delete</button>
                </td>
              </tr>
            `,
            )
            .join('');
          attachButtonEvents();
        } catch (err) {
          tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-red-600">Error: ${err.message}</td></tr>`;
        }
      }

      function attachButtonEvents() {
        document.querySelectorAll('.edit-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const description = btn.getAttribute('data-description');
            openModal(id, name, description);
          });
        });
        document.querySelectorAll('.delete-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-id');
            if (confirm('Are you sure you want to delete this category?')) {
              try {
                await del(`categories/${id}`);
                loadCategories();
              } catch (err) {
                alert(err.message);
              }
            }
          });
        });
      }

      function openModal(id = null, name = '', description = '') {
        currentEditId = id;
        document.getElementById('category-id').value = id || '';
        document.getElementById('category-name').value = name;
        document.getElementById('category-description').value = description;
        document.getElementById('modal-title').innerText = id
          ? 'Edit Category'
          : 'Add Category';
        const modal = document.getElementById('category-modal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
      }

      function closeModal() {
        const modal = document.getElementById('category-modal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.getElementById('category-form').reset();
        currentEditId = null;
      }

      function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, (m) => {
          if (m === '&') return '&amp;';
          if (m === '<') return '&lt;';
          if (m === '>') return '&gt;';
          return m;
        });
      }

      const form = document.getElementById('category-form');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const name = document.getElementById('category-name').value.trim();
          const description = document
            .getElementById('category-description')
            .value.trim();
          if (!name) {
            alert('Name is required');
            return;
          }
          const payload = { name };
          if (description) payload.description = description;
          try {
            if (currentEditId) {
              await put(`categories/${currentEditId}`, payload);
            } else {
              await post('categories', payload);
            }
            closeModal();
            loadCategories();
          } catch (err) {
            alert(err.message);
          }
        });
      }

      const createBtn = document.getElementById('create-category-btn');
      if (createBtn) createBtn.addEventListener('click', () => openModal());
      const closeBtn = document.getElementById('modal-close');
      if (closeBtn) closeBtn.addEventListener('click', closeModal);

      loadCategories();
    </script>
  </Section>
</AuthLayout>
