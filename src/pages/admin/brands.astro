---
import AuthLayout from '~/layouts/AuthLayout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
import Search from '~/components/admin/Search.astro';
---

<AuthLayout pageTitle="Manage Brands">
  <Section>
    <Container>
      <div class="bg-white rounded shadow p-6">
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-2xl font-bold">Brands</h1>
          <div class="flex items-center gap-3">
            <Search placeholder="Search brands..." id="admin-search" />
            <button
              id="create-brand-btn"
              class="bg-green-600 text-white px-4 py-1 rounded hover:bg-green-700"
              >+</button
            >
          </div>
        </div>

        <!-- Table container -->
        <div id="brands-table" class="overflow-x-auto">
          <table class="min-w-full border">
            <thead>
              <tr>
                <th class="border px-4 py-2">ID</th>
                <th class="border px-4 py-2">Name</th>
                <th class="border px-4 py-2">Logo URL</th>
                <th class="border px-4 py-2">Created At</th>
                <th class="border px-4 py-2">Actions</th>
              </tr>
            </thead>
            <tbody id="brands-tbody">
              <tr
                ><td colspan="5" class="text-center py-4"
                  >Loading...<\/td><\/tr>
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Modal for create/edit -->
        <div
          id="brand-modal"
          class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50"
        >
          <div class="bg-white rounded-lg p-6 w-full max-w-md">
            <h2 id="modal-title" class="text-xl font-bold mb-4">Add Brand</h2>
            <form id="brand-form">
              <input type="hidden" id="brand-id" />
              <div class="mb-4">
                <label class="block mb-1">Name</label>
                <input
                  type="text"
                  id="brand-name"
                  required
                  class="w-full border px-3 py-2 rounded"
                />
              </div>
              <div class="mb-4">
                <label class="block mb-1">Logo URL</label>
                <input
                  type="url"
                  id="brand-logo"
                  class="w-full border px-3 py-2 rounded"
                />
              </div>
              <div class="flex justify-end gap-2">
                <button
                  type="button"
                  id="modal-close"
                  class="px-4 py-2 border rounded">Cancel</button
                >
                <button
                  type="submit"
                  class="bg-blue-600 text-white px-4 py-2 rounded">Save</button
                >
              </div>
            </form>
          </div>
        </div>

        <script>
          import { createAdminTable } from '~/services/adminTable';

          createAdminTable({
            endpoint: 'brands',
            tbodyId: 'brands-tbody',
            modalId: 'brand-modal',
            formId: 'brand-form',
            createBtnId: 'create-brand-btn',
            closeBtnId: 'modal-close',
            modalTitleId: 'modal-title',
            idField: 'brand-id',
            columns: [
              { key: 'id' },
              { key: 'name', escape: true },
              {
                key: 'logo_url',
                render: (val) =>
                  val
                    ? `<a href="${val}" target="_blank" class="text-blue-600">Link</a>`
                    : '-',
              },
              {
                key: 'created_at',
                render: (val) => new Date(val).toLocaleDateString(),
              },
            ],
            fields: [
              { id: 'brand-name', key: 'name', required: true },
              { id: 'brand-logo', key: 'logo_url' },
            ],
          });
        </script>
      </div>
    </Container></Section
  ></AuthLayout
>
