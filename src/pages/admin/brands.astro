---
import AuthLayout from '~/layouts/AuthLayout.astro';
import Section from '~/components/Section.astro';
import Container from '~/components/Container.astro';
---

<AuthLayout pageTitle="Manage Brands">
  <Section>
    <Container>
      <div class="bg-white rounded shadow p-6">
        <div class="flex justify-between items-center mb-6">
          <h1 class="text-2xl font-bold">Brands</h1>
          <button
            id="create-brand-btn"
            class="bg-green-600 text-white px-4 py-2 rounded hover:bg-green-700"
          >
            + New Brand
          </button>
        </div>

        <!-- Table container -->
        <div id="brands-table" class="overflow-x-auto">
          <table class="min-w-full border">
            <thead>
              <tr>
                <th class="border px-4 py-2">ID</th>
                <th class="border px-4 py-2">Name</th>
                <th class="border px-4 py-2">Logo URL</th>
                <th class="border px-4 py-2">Created At</th>
                <th class="border px-4 py-2">Actions</th>
              </tr>
            </thead>
            <tbody id="brands-tbody">
              <tr
                ><td colspan="5" class="text-center py-4"
                  >Loading...<\/td><\/tr>
                </td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </Container>

    <!-- Modal for create/edit (hidden by default) -->
    <div
      id="brand-modal"
      class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50"
    >
      <div class="bg-white rounded-lg p-6 w-full max-w-md">
        <h2 id="modal-title" class="text-xl font-bold mb-4">Add Brand</h2>
        <form id="brand-form">
          <input type="hidden" id="brand-id" />
          <div class="mb-4">
            <label class="block mb-1">Name</label>
            <input
              type="text"
              id="brand-name"
              required
              class="w-full border px-3 py-2 rounded"
            />
          </div>
          <div class="mb-4">
            <label class="block mb-1">Logo URL</label>
            <input
              type="url"
              id="brand-logo"
              class="w-full border px-3 py-2 rounded"
            />
          </div>
          <div class="flex justify-end gap-2">
            <button
              type="button"
              id="modal-close"
              class="px-4 py-2 border rounded">Cancel</button
            >
            <button
              type="submit"
              class="bg-blue-600 text-white px-4 py-2 rounded">Save</button
            >
          </div>
        </form>
      </div>
    </div>

    <script>
      import { get, post, put, del } from '~/services/api';

      let currentEditId = null;

      async function loadBrands() {
        const tbody = document.getElementById('brands-tbody');
        tbody.innerHTML =
          '<tr><td colspan="5" class="text-center py-4">Loading...<\/td><\/tr>';
        try {
          const response = await get('brands');
          const brands = response.data || [];
          if (brands.length === 0) {
            tbody.innerHTML =
              '<tr><td colspan="5" class="text-center py-4">No brands found.<\/td><\/tr>';
            return;
          }
          tbody.innerHTML = brands
            .map(
              (brand) => `
        <tr>
          <td class="border px-4 py-2">${brand.id}<\/td>
          <td class="border px-4 py-2">${escapeHtml(brand.name)}<\/td>
          <td class="border px-4 py-2">${brand.logo_url ? `<a href="${brand.logo_url}" target="_blank" class="text-blue-600">Link</a>` : '-'}<\/td>
          <td class="border px-4 py-2">${new Date(brand.created_at).toLocaleDateString()}<\/td>
          <td class="border px-4 py-2">
            <button class="edit-btn text-blue-600 mr-2" data-id="${brand.id}" data-name="${escapeHtml(brand.name)}" data-logo="${brand.logo_url || ''}">Edit<\/button>
            <button class="delete-btn text-red-600" data-id="${brand.id}">Delete<\/button>
          <\/td>
        <\/tr>
      `,
            )
            .join('');
          attachButtonEvents();
        } catch (err) {
          tbody.innerHTML = `<tr><td colspan="5" class="text-center py-4 text-red-600">Error: ${err.message}<\/td><\/tr>`;
        }
      }

      function attachButtonEvents() {
        document.querySelectorAll('.edit-btn').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = btn.getAttribute('data-id');
            const name = btn.getAttribute('data-name');
            const logo = btn.getAttribute('data-logo');
            openModal(id, name, logo);
          });
        });
        document.querySelectorAll('.delete-btn').forEach((btn) => {
          btn.addEventListener('click', async () => {
            const id = btn.getAttribute('data-id');
            if (confirm('Are you sure you want to delete this brand?')) {
              try {
                await del(`brands/${id}`);
                loadBrands();
              } catch (err) {
                alert(err.message);
              }
            }
          });
        });
      }

      function openModal(id = null, name = '', logo = '') {
        currentEditId = id;
        document.getElementById('brand-id').value = id || '';
        document.getElementById('brand-name').value = name;
        document.getElementById('brand-logo').value = logo;
        document.getElementById('modal-title').innerText = id
          ? 'Edit Brand'
          : 'Add Brand';
        const modal = document.getElementById('brand-modal');
        modal.classList.remove('hidden');
        modal.style.display = 'flex';
      }

      function closeModal() {
        const modal = document.getElementById('brand-modal');
        modal.classList.add('hidden');
        modal.style.display = 'none';
        document.getElementById('brand-form').reset();
        currentEditId = null;
      }

      function escapeHtml(str) {
        if (!str) return '';
        return str.replace(/[&<>]/g, (m) => {
          if (m === '&') return '&amp;';
          if (m === '<') return '&lt;';
          if (m === '>') return '&gt;';
          return m;
        });
      }

      const form = document.getElementById('brand-form');
      if (form) {
        form.addEventListener('submit', async (e) => {
          e.preventDefault();
          const name = document.getElementById('brand-name').value.trim();
          const logo_url = document.getElementById('brand-logo').value.trim();
          if (!name) {
            alert('Name is required');
            return;
          }
          const payload = { name, logo_url: logo_url || undefined };
          try {
            if (currentEditId) {
              await put(`brands/${currentEditId}`, payload);
            } else {
              await post('brands', payload);
            }
            closeModal();
            loadBrands();
          } catch (err) {
            alert(err.message);
          }
        });
      }

      const createBtn = document.getElementById('create-brand-btn');
      if (createBtn) createBtn.addEventListener('click', () => openModal());
      const closeBtn = document.getElementById('modal-close');
      if (closeBtn) closeBtn.addEventListener('click', closeModal);

      loadBrands();
    </script></Section
  ></AuthLayout
>
